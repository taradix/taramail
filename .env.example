# Required. Primary cert CN. Must match a live/<SERVER_HOSTNAME>/ directory
# under /etc/letsencrypt once the cert has been issued.
SERVER_HOSTNAME=mail.taram.ca

# Recommended. Space-separated compose service names to SIGHUP after each
# successful renewal.
RELOAD_SERVICES=postfix dovecot nginx

# Set to 1 to generate /etc/letsencrypt/dhparams.pem (2048-bit) on first
# renewal. Postfix and dovecot reference this file for DHE ciphers.
GENERATE_DHPARAMS=1

# Timezone. See https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# (use the 'TZ identifier' column).
TZ=America/Toronto

# API. Set APIPASS to a long random alphanumeric string in your local .env
# (never commit it).
APIUSER=admin
#APIPASS=

# SQL database. Set DBPASS and DBROOT to long random alphanumeric strings
# (A-Za-z0-9) in your local .env (never commit them).
DBNAME=taram
DBUSER=taram
#DBPASS=
#DBROOT=

# Redis. Set REDIS_PASSWORD in your local .env (never commit it).
#REDIS_PASSWORD=

# Authentication. Set SECRET_KEY to a long random string in your local .env
# (never commit it).
#SECRET_KEY=

# Frontend configuration.
VITE_API_BASE_URL=http://172.22.1.5

# HTTP/HTTPS bindings. Leave the *_BIND empty for IPv4-any; set to an IP to
# restrict. Do not use IP:PORT in HTTP(S)_BIND or HTTP(S)_PORT.
# Avoid ports 8081, 9081, 65510 (reserved by internal services).
HTTP_PORT=1080
HTTP_BIND=
HTTPS_PORT=1443
HTTPS_BIND=

# Socketmap port for Postfix relay domain lookups (queried by taramx).
# Set SOCKETMAP_BIND to an IP to restrict which interface it listens on.
SOCKETMAP_PORT=10028
SOCKETMAP_BIND=

# Mail protocol bindings. You should leave these alone.
# Format: 11.22.33.44:25 or 12.34.56.78:465 etc.
SMTP_PORT=25
SMTPS_PORT=465
SUBMISSION_PORT=587
IMAP_PORT=143
IMAPS_PORT=993
POP_PORT=110
POPS_PORT=995
SIEVE_PORT=4190
DOVEADM_PORT=127.0.0.1:19991

# DMARC report processor. Set DMARC_IMAP_USER and DMARC_IMAP_PASSWORD to the
# credentials of the mailbox receiving DMARC reports (never commit them).
#DMARC_IMAP_USER=
#DMARC_IMAP_PASSWORD=
DMARC_POLL_INTERVAL=3600

# COMPOSE_PROJECT_NAME is set automatically by docker compose (defaults to the
# project directory name). Override it here only if you need a non-default
# name — docker-reload.py uses it to locate sibling containers.
#COMPOSE_PROJECT_NAME=taramail

# Internal IPv4 /24 subnet, format n.n.n (expands to n.n.n.0/24).
# Use a private range: https://en.wikipedia.org/wiki/Private_network#Private_IPv4_addresses
IPV4_NETWORK=172.22.1

# Optional. Use this IPv4 for outgoing connections (SNAT).
#SNAT_TO_SOURCE=
